#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@UI_CORE_INTERNAL_VERSION@
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,@UI_CORE_INTERNAL_VERSION@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE @VERSION_FILE_TYPE@
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404B0"
        BEGIN
            VALUE "CompanyName", "Core UI\0"
            VALUE "FileDescription", "@VERSION_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@PROJECT_VERSION@.@UI_CORE_INTERNAL_VERSION@\0"
            VALUE "InternalName", "@VERSION_INTERNAL_NAME@\0"
            VALUE "OriginalFilename", "@VERSION_ORIGINAL_FILENAME@\0"
            VALUE "ProductName", "Core UI\0"
            VALUE "ProductVersion", "@UI_CORE_VERSION_TAG@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0804, 1200
    END
END
