          <label class="lbl">{{ $t('status_ul') }} {{ ul }}%</label>
          <progressbar min="0" max="100" :value="ul"/>
          <label class="lbl">{{ $t('status_done') }} {{ done }}%</label>
          <progressbar min="0" max="100" :value="done"/>
        </div>
        <label class="h2">{{ $t('status_badges') }}</label>
        <div class="row">
          <label class="badge info">INFO</label>
          <label class="badge ok">OK</label>
          <label class="badge warn">WARN</label>
          <label class="badge err">ERR</label>
        </div>
      </div>

      <!-- ===== 列表 ===== -->
      <div v-if="page=='list'">
        <label class="h1">{{ $t('list_title') }}</label>
        <label class="desc">{{ $t('list_desc') }}</label>
        <div class="sep"/>
        <div class="panel">
          <label class="h2">{{ itemCount }} {{ $t('list_items') }} · {{ doneCount }} {{ $t('list_done') }} · {{ pending }} {{ $t('list_pending') }}</label>
          <div v-for="(item, i) in items" :key="item.id" class="row">
            <input type="checkbox" :checked="item.done" @change="toggleDone(item)"/>
            <label :class="item.done ? 'item done' : 'item'">{{ i }}: #{{ item.id }} {{ item.label }}</label>
            <button class="danger" @click="removeItem(item)">×</button>
          </div>
          <div class="row">
            <button id="btnListAdd"     @click="addItem">{{ $t('list_add') }}</button>
            <button id="btnListReverse" @click="reverseList" class="subtle">{{ $t('list_reverse') }}</button>
            <button id="btnListClear"   @click="clearList"   class="danger">{{ $t('list_clear') }}</button>
          </div>
        </div>
      </div>

      <!-- ===== 事件 ===== -->
      <div v-if="page=='events'">
        <label class="h1">{{ $t('events_title') }}</label>
        <label class="desc">{{ $t('events_desc') }}</label>
        <div class="sep"/>
        <div class="panel">
          <div class="row">
            <button @click="onClick">click</button>
            <button @dblclick="onDblClick">dblclick</button>
          </div>
          <input v-model="name" @focus="onFocus" @blur="onBlur"
                 placeholder="focus / blur"/>
          <div id="evboxRoot" class="evbox" @mousedown="onMouseDown" @mouseup="onMouseUp"
               @wheel="onWheel" @click="onClick">
            {{ $t('events_box') }}
          </div>
          <label class="evlog">{{ eventCount }} {{ $t('events_count') }} · {{ $t('events_last') }}: {{ lastEvent }}</label>

          <menu trigger="#evboxRoot" event="rclick">
            <menuitem id="1" onclick="onClick" shortcut="Ctrl+C">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 9h10v10H9zM5 5h10v2H7v8H5z"/></svg>
              复制
            </menuitem>
            <menuitem id="2" onclick="onClick" shortcut="Ctrl+X">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 9.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5zM6 19.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5zM20 4L8.12 15.88M14.47 14.48L20 20M8.12 8.12L12 12"/></svg>
              剪切
            </menuitem>
            <separator/>
            <menuitem id="3" onclick="onClick" shortcut="Ctrl+E">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 20h9M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              编辑
            </menuitem>
            <menuitem id="4" onclick="onClick" shortcut="Ctrl+Shift+X">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M6 2v14a2 2 0 0 0 2 2h14M6 6l16 16M22 6h-4M22 22h-4"/></svg>
              裁剪
            </menuitem>
            <separator/>
            <menuitem id="5" onclick="onClick" shortcut="F5">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/></svg>
              幻灯片
            </menuitem>
            <menuitem id="6" onclick="onClick" shortcut="F11">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3 8V5a2 2 0 0 1 2-2h3M3 16v3a2 2 0 0 0 2 2h3M21 8V5a2 2 0 0 0-2-2h-3M21 16v3a2 2 0 0 1-2 2h-3"/></svg>
              全屏
            </menuitem>
            <separator/>
            <menuitem id="7" onclick="onClick" shortcut="Alt+Enter">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 16v-4M12 8h.01" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              属性信息
            </menuitem>
            <menuitem id="8" onclick="onClick" shortcut="Ctrl+W">
              <svg viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18 6L6 18M6 6l12 12"/></svg>
              关闭
            </menuitem>
          </menu>
        </div>
      </div>

      <!-- ===== 布局 ===== -->
      <div v-if="page=='layout'">
        <label class="h1">{{ $t('layout_title') }}</label>
        <label class="desc">{{ $t('layout_desc') }}</label>
        <div class="sep"/>
        <label class="h2">{{ $t('layout_hbox') }}</label>
        <div class="panel">
          <div class="row">
            <button>{{ $t('layout_left') }}</button>
            <div style="flex: 1"/>
            <button>{{ $t('layout_center') }}</button>
            <div style="flex: 1"/>
            <button>{{ $t('layout_right') }}</button>
          </div>
        </div>
        <label class="h2">{{ $t('layout_pct') }}</label>
        <div class="panel">
          <div class="row">
            <button class="success" style="width: 25%">25%</button>
            <button style="width: 50%">50%</button>
            <button class="danger" style="width: 25%">25%</button>
          </div>
        </div>
        <label class="h2">{{ $t('layout_sep') }}</label>
        <div class="panel">
          <label class="lbl">A</label>
          <div class="sep"/>
          <label class="lbl">B</label>
          <div class="sep"/>
          <label class="lbl">C</label>
        </div>
      </div>

      <!-- ===== 样式 ===== -->
      <div v-if="page=='style'">
        <label class="h1">{{ $t('style_title') }}</label>
        <label class="desc">{{ $t('style_desc') }}</label>
        <div class="sep"/>
        <label class="h2">{{ $t('style_dynamic') }}</label>
        <div class="panel">
          <label :class="count > 5 ? 'item done' : 'item'">
            {{ $t('style_fade') }} (count = {{ count }}, {{ count > 5 ? $t('style_faded') : $t('style_normal') }})
          </label>
          <button @click="inc">count++</button>
        </div>
      </div>

      <!-- ===== i18n ===== -->
      <div v-if="page=='i18n'">
        <label class="h1">{{ $t('i18n_title') }}</label>
        <label class="desc">{{ $t('i18n_desc') }}</label>
        <div class="sep"/>
        <div class="panel">
          <label class="h2">{{ $t('greeting_hello') }}</label>
          <label class="lbl">{{ $t('greeting_welcome') }}</label>
          <label class="lbl">current locale = {{ $locale }}</label>
        </div>
        <label class="h2">{{ $t('i18n_switch') }}</label>
        <div class="row">
          <button @click="setLang('zh')" :class="$locale=='zh' ? '' : 'subtle'">中文</button>
          <button @click="setLang('en')" :class="$locale=='en' ? '' : 'subtle'">English</button>
        </div>
        <label class="lbl">{{ $t('i18n_note') }}</label>
      </div>

      <!-- ===== 设置 ===== -->
      <div v-if="page=='settings'">
        <label class="h1">{{ $t('settings_title') }}</label>
        <div class="sep"/>
        <label class="h2">{{ $t('settings_lang') }}</label>
        <div class="row">
          <button @click="setLang('zh')" :class="$locale=='zh' ? '' : 'subtle'">中文</button>
          <button @click="setLang('en')" :class="$locale=='en' ? '' : 'subtle'">English</button>
        </div>
        <label class="h2">{{ $t('settings_appearance') }}</label>
        <div class="row">
          <toggle id="darkSwitch" v-model="dark"/>
          <label class="lbl">{{ $t('settings_dark') }}</label>
        </div>
        <label class="h2">{{ $t('settings_about') }}</label>
        <div class="panel">
          <label class="lbl">Core UI 1.5.x · QuickJS-NG v0.14.0</label>
          <label class="lbl">Direct2D · DirectWrite · Win32</label>
          <label class="lbl">{{ $t('settings_about_desc') }}</label>
        </div>
      </div>

    </div>
  </div>
</div>
</template>
