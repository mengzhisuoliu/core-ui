<window title="Core UI .uix Demo" width="1100" height="720"
        min-width="700" min-height="500"
        resizable="true" centered="true" frameless="true" theme="light"/>

<script>
// ui-demo .uix port + new feature pages, all in one file. Default locale
// is zh (Simplified Chinese); the i18n page lets the user switch to en
// and back. Driver-side cpp polls state.requestedLocale via SetTimer
// and forwards to ui_page_set_locale, since methods{} can't call C
// directly.
export default {
  data() {
    return {
      page: "home",
      requestedLocale: "zh",   // C-side timer watches this and calls set_locale

      // ---- Reactive page ----
      count: 0,

      // ---- Selection page ----
      agreeA: true,  agreeB: false,  agreeC: true,
      sizeS: false,  sizeM: true,    sizeL: false,
      wifi: true,    bt: false,      notif: true,
      color: 0,

      // ---- Input page ----
      name: "Alice",
      email: "alice@example.com",
      pw: "",
      bio: "在这里输入多行文本……",

      // ---- Range page ----
      vol: 65,
      bright: 80,
      zoom: 100,
      n_int: 42,
      n_dec: 0.5,

      // ---- Status page ----
      dl: 73, ul: 45, done: 100,

      // ---- List page ----
      items: [
        { id: 1, label: "alpha",   done: false },
        { id: 2, label: "beta",    done: true  },
        { id: 3, label: "gamma",   done: false }
      ],

      // ---- Events page ----
      lastEvent: "(none)",
      eventCount: 0,

      // ---- Settings page ----
      dark: false
    };
  },

  computed: {
    doubled()    { return this.count * 2; },
    triple()     { return this.count + this.doubled; },
    canSave()    { return this.name.length > 0; },
    itemCount()  { return this.items.length; },
    doneCount()  { return this.items.filter(x => x.done).length; },
    pending()    { return this.itemCount - this.doneCount; },
    colorName()  {
      var names = ["蓝", "绿", "红", "黄", "紫"];
      return names[this.color] || "—";
    }
  },

  methods: {
    nav(p) { this.page = p; },

    setLang(loc) { this.requestedLocale = loc; },

    // Reactive
    inc()   { this.count++; },
    dec()   { this.count--; },
    reset() { this.count = 0; },

    // List
    addItem() {
      var next = this.items.slice();
      next.push({ id: Date.now(),
                   label: "项目-" + (this.items.length + 1),
                   done: false });
      this.items = next;
    },
    removeItem(item) {
      this.items = this.items.filter(x => x.id !== item.id);
    },
    toggleDone(item) {
      this.items = this.items.map(x =>
        x.id === item.id ? { id: x.id, label: x.label, done: !x.done } : x);
    },
    reverseList() { this.items = this.items.slice().reverse(); },
    clearList()   { this.items = []; },

    // Events
    probe(name, ev) {
      this.eventCount++;
      var pos = ev && typeof ev === "object" && "x" in ev
              ? ` @(${Math.round(ev.x)},${Math.round(ev.y)})` : "";
      var dl  = ev && typeof ev === "object" && ev.delta
              ? ` Δ${ev.delta}` : "";
      this.lastEvent = `${name}${pos}${dl}`;
    },
    onClick($e)     { this.probe("click",     $e); },
    onDblClick($e)  { this.probe("dblclick",  $e); },
    onMouseDown($e) { this.probe("mousedown", $e); },
    onMouseUp($e)   { this.probe("mouseup",   $e); },
    onWheel($e)     { this.probe("wheel",     $e); },
    onFocus()       { this.probe("focus",     null); },
    onBlur()        { this.probe("blur",      null); }
  }
}
</script>

<style>
  /* ============ shell ============
     All container surfaces / text colors come from library-provided CSS
     vars (--bg / --fg / --sidebar-bg / --card-bg / ...). Calling
     ui_theme_set_mode flips the var values in place and re-cascades, so
     no `.dark`-prefixed duplicate rules are needed. */
  .shell    { gap: 0; background: var(--bg); }
  .body     { flex-direction: row; gap: 0; flex: 1; }

  /* sidebar */
  .sidebar  { width: 220; padding: 4px; gap: 1px; background: var(--sidebar-bg); }
  .nav      { flex-direction: row; align-items: center; gap: 10px;
              padding: 0 12px; height: 36px; border-radius: 4px;
              cursor: pointer; }
  .nav:hover{ background: var(--sidebar-hover); }
  .nav.on   { background: var(--bg-3); }
  .nav.on .nav-bar { background: var(--accent); }
  .nav-bar  { width: 3px; height: 18px; border-radius: 2px; background: transparent; }
  .nav-icon { width: 20px; height: 20px; color: var(--sidebar-text); }
  .nav-text { font-size: 13px; color: var(--sidebar-text); }
  .nav.on .nav-icon { color: var(--fg); }
  .nav.on .nav-text { color: var(--fg); font-weight: 600; }
  .nav-spacer { flex: 1; }
  .nav-sep  { height: 1; background: var(--border-subtle); margin: 4px 8px; }

  /* content */
  .content  { padding: 32px 40px; gap: 14px; flex: 1; background: var(--bg); }
  .h1       { font-size: 26px; color: var(--fg); font-weight: 700; }
  .desc     { font-size: 14px; color: var(--fg-3); }
  .sep      { height: 1; background: var(--border-subtle); }
  .h2       { font-size: 15px; color: var(--fg); font-weight: 600;
              padding-top: 6px; }
  .lbl      { font-size: 13px; color: var(--fg-2); }
  .item     { font-size: 14px; color: var(--fg); }
  .item.done{ color: var(--fg-4); }
  .row      { flex-direction: row; gap: 8px; align-items: center; }

  /* home cards */
  .crow     { flex-direction: row; gap: 16px; }
  .card     { padding: 16px; gap: 6px; flex: 1; background: var(--card-bg);
              border-radius: 6px; }
  .card .h2 { font-size: 15px; color: var(--fg); font-weight: 600; padding-top: 0; }
  .card .lbl{ font-size: 12px; color: var(--fg-3); }

  .panel    { padding: 14px; gap: 8px; background: var(--card-bg); border-radius: 6px; }

  /* buttons */
  button         { background: var(--accent); color: #ffffff; padding: 6px 14px;
                   border-radius: 4px; cursor: pointer; font-size: 13px; }
  button:hover   { opacity: 0.9; }
  button.danger  { background: #ef4444; }
  button.subtle  { background: #6b7280; }
  button.success { background: #22c55e; }
  button.warning { background: #eab308; }
  button.purple  { background: #8b5cf6; }
  button:disabled{ background: #9ca3af; cursor: default; }

  /* status badges */
  .badge      { font-size: 11px; padding: 2px 8px; border-radius: 10px;
                color: #ffffff; }
  .badge.info { background: var(--accent); }
  .badge.ok   { background: #22c55e; }
  .badge.warn { background: #eab308; color: #1f2937; }
  .badge.err  { background: #ef4444; }

  .evbox    { padding: 28px; background: #fef3c7; border-radius: 6px;
              color: #78350f; font-size: 13px; cursor: pointer;
              min-height: 60px; align-items: center; }
  .evlog    { padding: 8px 12px; background: var(--bg-2); border-radius: 4px;
              font-size: 12px; color: var(--fg); }

  /* progress bar — flex of 2 divs simulates filled/empty track */
  .pbar     { flex-direction: row; height: 8; border-radius: 4;
              background: var(--bg-3); }
  .pfill    { background: var(--accent); border-radius: 4; }
</style>

